# OpenClaw Docker Configuration

# Image definition
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Security
# Run: `openssl rand -hex 32` to generate a secure token
OPENCLAW_GATEWAY_TOKEN=your_random_token_here

# Network properties
OPENCLAW_GATEWAY_BIND=0.0.0.0
OPENCLAW_GATEWAY_PORT=18789

# Data persistence
# Use absolute paths or standard Docker volumes
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace

# Other settings
NODE_ENV=production
GOG_KEYRING_PASSWORD=change_me
XDG_CONFIG_HOME=/home/node/.openclaw
