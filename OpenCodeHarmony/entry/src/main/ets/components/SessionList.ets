import { OpenCodeCore, OpenCodeBackend, OpenCodeSession } from '../core/OpenCodeCore';
import router from '@ohos.router';

interface SessionDisplayItem {
  id: string;
  name: string;
  backendUrl: string;
  backendId: string;
  directory: string;
  updatedAt: string;
  isWorking: boolean;
  unreadCount: number;
  session: OpenCodeSession;
}

@Component
export struct SessionList {
  @State sessions: SessionDisplayItem[] = [];
  @State backends: OpenCodeBackend[] = [];
  @State selectedBackendId: string = '';
  @State isLoading: boolean = false;
  @StorageLink('refreshSessionsNow') @Watch('onRefreshNow') refreshSessionsNow: string = '';
  private core: OpenCodeCore = OpenCodeCore.getInstance();

  aboutToAppear() {
    this.backends = this.core.getBackends();
    if (this.backends.length > 0) {
      this.selectedBackendId = this.backends[0].id;
    }
    this.refreshSessions();
  }

  aboutToDisappear() {
  }

  onRefreshNow() {
    if (this.refreshSessionsNow) {
      console.info('[SessionList] onRefreshNow triggered, value:', this.refreshSessionsNow);
      this.refreshSessions();
    }
  }

  async refreshSessions() {
    this.isLoading = true;
    try {
      this.backends = this.core.getBackends();
      if (!this.selectedBackendId && this.backends.length > 0) {
        this.selectedBackendId = this.backends[0].id;
      }
      const localSessions = this.core.getSessions();
      console.info('[SessionList] Loading local sessions:', localSessions.length);
      localSessions.forEach(s => {
        const p = this.core.getProjectById(s.id);
        console.info(`[SessionList] session=${s.id} isWorking=${p?.isWorking} unread=${p?.unreadCount}`);
      });
      
      this.sessions = localSessions.map((s): SessionDisplayItem => {
        const project = this.core.getProjectById(s.id);
        return {
          id: s.id,
          name: s.name,
          backendUrl: s.backendUrl,
          backendId: s.backendId,
          directory: s.directory,
          updatedAt: s.updatedAt,
          isWorking: project?.isWorking ?? false,
          unreadCount: project?.unreadCount ?? 0,
          session: {
            id: s.id,
            projectID: '',
            directory: s.directory,
            title: s.name,
            version: '1',
            time: { created: 0, updated: 0 }
          }
        };
      });
    } catch (e) {
      console.error('[SessionList] Failed to load sessions:', e);
      this.sessions = [];
    } finally {
      this.isLoading = false;
    }
  }

  build() {
    Column() {
      Row() {
        Text('会话')
          .fontSize(20)
          .fontWeight(FontWeight.Bold)
        Blank()
        Text('+')
          .fontSize(28)
          .fontColor('#07C160')
          .onClick(() => {
            router.pushUrl({
              url: 'pages/SessionDetail',
              params: {
                backendId: this.selectedBackendId,
                backendUrl: this.backends.find(b => b.id === this.selectedBackendId)?.url || '',
                username: this.backends.find(b => b.id === this.selectedBackendId)?.username || '',
                authToken: this.backends.find(b => b.id === this.selectedBackendId)?.authToken || ''
              }
            });
          })
      }
      .width('100%')
      .padding({
        left: 20,
        right: 20,
        top: 15,
        bottom: 15
      })
      .backgroundColor('#EDEDED')

      if (this.backends.length === 0) {
        Column({ space: 16 }) {
          Stack() {
            Circle()
              .width(80)
              .height(80)
              .fill('#F0F5FF')
            Text('💬')
              .fontSize(36)
          }
          .margin({ bottom: 8 })
          Text('暂无后端连接')
            .fontSize(18)
            .fontWeight(FontWeight.Medium)
            .fontColor('#333333')
          Text('请先在"后端"页签添加 OpenCode 服务器')
            .fontSize(14)
            .fontColor('#999999')
            .textAlign(TextAlign.Center)
        }
        .width('100%')
        .height('100%')
        .backgroundColor('#FFFFFF')
        .justifyContent(FlexAlign.Center)
        .alignItems(HorizontalAlign.Center)
      } else {
        if (this.isLoading) {
          Column() {
            LoadingProgress()
              .width(48)
              .height(48)
            Text('加载中...')
              .fontSize(14)
              .fontColor('#999999')
              .margin({ top: 12 })
          }
          .width('100%')
          .height('100%')
          .justifyContent(FlexAlign.Center)
          .alignItems(HorizontalAlign.Center)
        } else if (this.sessions.length === 0) {
          Column({ space: 16 }) {
            Stack() {
              Circle()
                .width(80)
                .height(80)
                .fill('#F0F5FF')
              Text('💬')
                .fontSize(36)
            }
            .margin({ bottom: 8 })
            Text('暂无会话')
              .fontSize(18)
              .fontWeight(FontWeight.Medium)
              .fontColor('#333333')
            Text('点击右上角 + 新建会话')
              .fontSize(14)
              .fontColor('#999999')
            Button('新建会话', { type: ButtonType.Normal })
              .width(160)
              .height(44)
              .borderRadius(22)
              .backgroundColor('#07C160')
              .fontColor('#FFFFFF')
              .fontSize(15)
              .margin({ top: 8 })
              .onClick(() => {
                router.pushUrl({
                  url: 'pages/SessionDetail',
                  params: {
                    backendId: this.selectedBackendId,
                    backendUrl: this.backends.find(b => b.id === this.selectedBackendId)?.url || '',
                    username: this.backends.find(b => b.id === this.selectedBackendId)?.username || '',
                    authToken: this.backends.find(b => b.id === this.selectedBackendId)?.authToken || ''
                  }
                });
              })
          }
          .width('100%')
          .height('100%')
          .backgroundColor('#FFFFFF')
          .justifyContent(FlexAlign.Center)
          .alignItems(HorizontalAlign.Center)
        } else {
          List() {
            ForEach(this.sessions, (item: SessionDisplayItem) => {
              ListItem() {
                Row() {
                  Stack({ alignContent: Alignment.TopEnd }) {
                    Rect().fill('#07C160').width(48).height(48).borderRadius(8)
                    Text(item.name.charAt(0).toUpperCase())
                      .fontSize(20).fontColor('#FFFFFF').fontWeight(FontWeight.Bold)
                    
                    // hasPendingWork 由 isWorking || unreadCount 派生
                    if (item.isWorking) {
                      Circle().width(12).height(12)
                        .fill('#2196F3')
                        .stroke('#FFFFFF')
                        .strokeWidth(2)
                        .offset({ x: 4, y: -4 })
                    } else if (item.unreadCount > 0) {
                      Circle().width(12).height(12)
                        .fill('#FF3B30')
                        .stroke('#FFFFFF')
                        .strokeWidth(2)
                        .offset({ x: 4, y: -4 })
                    }
                  }
                  .width(48).height(48)
                  .margin({ right: 16 })

                  Column() {
                    Text(item.name)
                      .fontSize(16)
                      .fontWeight(FontWeight.Medium)
                      .maxLines(1)
                    Row() {
                      Text('后端: ' + (this.backends.find(b => b.id === item.backendId)?.notes || item.backendUrl))
                        .fontSize(11)
                        .fontColor('#07C160')
                        .maxLines(1)
                        .textOverflow({ overflow: TextOverflow.Ellipsis })
                      Text(' | ')
                        .fontSize(11)
                        .fontColor('#CCCCCC')
                      Text(item.directory || '/')
                        .fontSize(11)
                        .fontColor('#888888')
                        .maxLines(1)
                        .textOverflow({ overflow: TextOverflow.Ellipsis })
                        .layoutWeight(1)
                      // hasPendingWork = isWorking || unreadCount > 0（未读数标记）
                      if (item.unreadCount > 0) {
                        Text(`${item.unreadCount}`)
                          .fontSize(10)
                          .fontColor('#FFFFFF')
                          .backgroundColor('#FF3B30')
                          .borderRadius(8)
                          .padding({ left: 6, right: 6, top: 2, bottom: 2 })
                          .margin({ left: 4 })
                      }
                    }
                    .margin({ top: 2 })
                    Text(item.updatedAt)
                      .fontSize(11)
                      .fontColor('#AAAAAA')
                      .margin({ top: 2 })
                  }
                  .layoutWeight(1)
                  .alignItems(HorizontalAlign.Start)

                  Row({ space: 8 }) {
                    Text('配置')
                      .fontSize(13)
                      .fontColor('#1677FF')
                      .padding(8)
                      .onClick(() => {
                        const backend = this.backends.find(b => b.id === item.backendId);
                        router.pushUrl({
                          url: 'pages/SessionDetail',
                          params: {
                            backendId: item.backendId,
                            backendUrl: item.backendUrl,
                            username: backend?.username || '',
                            authToken: backend?.authToken || '',
                            title: item.name,
                            directory: item.directory,
                            isEditing: true,
                            id: item.id
                          }
                        });
                      })

                    Text('删除')
                      .fontSize(13)
                      .fontColor('#FF4D4F')
                      .padding(8)
                      .onClick(() => {
                        AlertDialog.show({
                          title: '删除会话',
                          message: `确定要删除会话 "${item.name}" 吗？`,
                          primaryButton: {
                            value: '取消',
                            action: () => {}
                          },
                          secondaryButton: {
                            value: '删除',
                            fontColor: '#FF4D4F',
                            action: () => {
                              this.core.removeProject(item.id);
                            }
                          }
                        });
                      })
                  }
                }
                .width('100%')
                .padding({
                  left: 16,
                  right: 16,
                  top: 12,
                  bottom: 12
                })
                .backgroundColor('#FFFFFF')
              }
              .onClick(() => {
                this.core.setCurrentProject(item.id);
                this.core.setCurrentSession(item.id);
                router.pushUrl({
                  url: 'pages/ChatPage',
                  params: {
                    sessionId: item.id,
                    sessionName: item.name,
                    backendUrl: item.backendUrl,
                    username: this.backends.find(b => b.id === item.backendId)?.username || '',
                    authToken: this.backends.find(b => b.id === item.backendId)?.authToken || '',
                    directory: item.directory
                  }
                });
              })
            }, (item: SessionDisplayItem) => item.id)
          }
          .divider({ strokeWidth: 0.5, color: '#EEEEEE', startMargin: 76 })
          .backgroundColor('#FFFFFF')
          .flexGrow(1)
        }
      }
    }
    .width('100%')
    .backgroundColor('#EDEDED')
  }
}
